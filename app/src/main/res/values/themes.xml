<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KKM" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowActivityTransitions">true</item>
    </style>
    <style name="Theme.KKM.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1A5276</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.KKM</item>
    </style>
</resources>
